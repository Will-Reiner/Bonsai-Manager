# Auto-detect text files and normalize to LF on commit
* text=auto eol=lf

# Shell scripts must always be LF (executed by Linux containers)
*.sh text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files - leave untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
