# ======================================
# Bonsai Manager - Variáveis de Ambiente
# ======================================
# Copie este arquivo para .env e preencha os valores.
# Não faça commit do arquivo .env!

# --- Banco de Dados PostgreSQL ---
POSTGRES_USER=bonsai_user
POSTGRES_PASSWORD=bonsai_pass
POSTGRES_DB=bonsai_db

# --- Autenticação JWT ---
# IMPORTANTE: Em produção, use uma string longa e aleatória!
JWT_SECRET=changeme_dev_secret
